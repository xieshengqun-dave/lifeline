# Copy to .env.test. Points at a SEPARATE database from your dev .env —
# tests wipe this database between runs, so it must never be the same DB
# your seeded dev data lives in.
#
# One-time setup: createdb -U lifeline lifeline_test
DATABASE_URL="postgresql://lifeline:lifeline_dev_pw@localhost:5432/lifeline_test?schema=public"
PORT=4001

JWT_SECRET="test-secret-not-for-production"
OFFER_TIMEOUT_SECONDS=60
OFFER_SWEEP_INTERVAL_SECONDS=15
PLATFORM_SERVICE_FEE=15
ADMIN_API_TOKEN="test-admin-token"
ALLOW_UNVERIFIED_SOCIAL_AUTH=true
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
