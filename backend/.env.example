# Copy to .env and fill in. Railway/Render give you DATABASE_URL automatically.
DATABASE_URL="postgresql://user:password@localhost:5432/lifeline?schema=public"
PORT=4000

# Generate your own: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET="change-me"

# Accept/decline window per operator offer, and how often the safety-net
# sweep checks for expired offers whose in-memory timer may have been lost
# (e.g. across a server restart before recovery runs).
OFFER_TIMEOUT_SECONDS=60
OFFER_SWEEP_INTERVAL_SECONDS=15

# Flat platform fee in RM, matches the frontend's existing SERVICE_FEE
# constant. TODO(human/business): confirm real commission structure.
PLATFORM_SERVICE_FEE=15

# Static shared-secret for the 3 admin endpoints — no admin user table yet
# (no admin UI exists until Phase 4). Pilot-only.
ADMIN_API_TOKEN="change-me"

# Google / Apple sign-in — TODO(human): real provider verification needs
# GOOGLE_CLIENT_ID / APPLE_CLIENT_ID (and Apple's private key) from real
# developer accounts. Until then, POST /api/auth/google|apple return 501
# UNLESS this is true, in which case the client-supplied name/email is
# trusted without verification (dev-only — every such call logs a warning
# and the response is flagged devModeUnverified: true).
ALLOW_UNVERIFIED_SOCIAL_AUTH=false
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
